---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import intro from "../data/intro.json";
import { jobs } from "../data/work.json";
import { projects } from "../data/projects.json";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const dateFormat = new Intl.DateTimeFormat("en", {
  month: "short",
  year: "numeric",
});
---

<Base title="sahil pabale" description="backend engineer — solana, rust, and the plumbing of markets.">
  <main>
    <header>
      <h1>Sahil Pabale</h1>
      <p class="meta">{intro.tagline}</p>
    </header>

    <section class="intro">
      {intro.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </section>

    <section>
      <p class="section-label">Work</p>
      <ul class="works">
        {
          jobs.map((job) => (
            <li>
              <div class="work-row">
                <span class="work-name">
                  <a href={job.link}>{job.name}</a>
                  <span class="work-role">· {job.role}</span>
                </span>
                <span class="work-year">{job.year}</span>
              </div>
              <p class="work-line">{job.line}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section>
      <p class="section-label">Projects</p>
      <ul class="works">
        {
          projects.map((project) => (
            <li>
              <div class="work-row">
                <span class="work-name">
                  <a href={project.link}>{project.name}</a>
                </span>
                <span class="work-year">{project.year}</span>
              </div>
              <p class="work-line">{project.line}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section>
      <p class="section-label">Writing</p>
      <ul class="posts">
        {
          posts.map((post) => (
            <li class="post-row">
              <a href={`/writing/${post.id}/`}>{post.data.title}</a>
              <span class="post-date">{dateFormat.format(post.data.date)}</span>
            </li>
          ))
        }
      </ul>
      <p class="all-posts">
        <a href="/writing/">all writing</a>
      </p>
    </section>
  </main>
</Base>

<style>
  .intro {
    margin-top: 2.25rem;
  }

  section {
    margin-top: 3.25rem;
  }

  .intro p + p {
    margin-top: 1.1em;
  }

  header .meta {
    margin-top: 0.25rem;
  }

  .works,
  .posts {
    list-style: none;
  }

  .works li + li {
    margin-top: 1.1rem;
  }

  .work-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .work-name {
    font-family: var(--sans);
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .work-name a {
    text-decoration: none;
  }

  .work-name a:hover {
    text-decoration: underline;
    text-decoration-color: var(--muted);
    text-underline-offset: 3px;
  }

  .work-role {
    color: var(--muted);
    font-weight: 400;
  }

  .work-year,
  .post-date {
    font-style: italic;
    color: var(--muted);
    font-size: 0.95rem;
    white-space: nowrap;
  }

  .work-line {
    margin-top: 0.15rem;
  }

  .post-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .posts li + li {
    margin-top: 0.6rem;
  }

  .all-posts {
    margin-top: 1.25rem;
  }

  .all-posts a {
    font-family: var(--sans);
    font-size: 0.8125rem;
    text-decoration: none;
    color: var(--muted);
  }

  .all-posts a:hover {
    color: var(--text);
  }
</style>
