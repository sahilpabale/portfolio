---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const posts = (await getCollection("writing", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const dateFormat = new Intl.DateTimeFormat("en", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
---

<Base title="writing · sahil pabale" description="writings of sahil pabale.">
  <main>
    <header>
      <h1><a href="/" class="back">Sahil Pabale</a> <span class="crumb">/ writing</span></h1>
    </header>

    <ul class="posts">
      {
        posts.map((post) => (
          <li class="post-row">
            <a href={`/writing/${post.id}/`}>{post.data.title}</a>
            <span class="post-date">{dateFormat.format(post.data.date)}</span>
          </li>
        ))
      }
    </ul>
  </main>
</Base>

<style>
  .back {
    text-decoration: none;
  }

  .crumb {
    color: var(--muted);
    font-weight: 400;
  }

  .posts {
    list-style: none;
    margin-top: 2.25rem;
  }

  .post-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .posts li + li {
    margin-top: 0.75rem;
  }

  .post-date {
    font-style: italic;
    color: var(--muted);
    font-size: 0.95rem;
    white-space: nowrap;
  }
</style>
